meta {
  name: Get Access Token
  type: http
  seq: 2
}

post {
  url: {{auth_url}}/oauth2/token
  body: formUrlEncoded
  auth: basic
}

auth:basic {
  username: {{client_id}}
  password: {{client_secret}}
}

body:form-urlencoded {
  grant_type: client_credentials
  scope: read openid
}

script:post-response {
  bru.setVar("access_token", res.body.access_token);
}

settings {
  encodeUrl: true
  timeout: 0
}
